{
  "name": "@layerv/qurl",
  "version": "0.1.0",
  "description": "TypeScript SDK for the QURL API - secure, time-limited access links",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "qurl",
    "layerv",
    "security",
    "ai-agents",
    "zero-trust"
  ],
  "author": "LayerV AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/layervai/qurl-typescript"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.0.3",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "access": "public"
  }
}
